<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Adibas Host</title>

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

html {
    scroll-behavior: smooth;
}

body {
    background: #f4f7fb;
    color: #333;
}

/* NAV */
nav {
    background: #0d1b2a;
    color: white;
    padding: 15px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

nav h2 {
    color: #4cc9f0;
}

nav a {
    color: white;
    margin-left: 20px;
    text-decoration: none;
}

nav a:hover {
    color: #4cc9f0;
}

/* HERO */
.hero {
    background: linear-gradient(135deg, #1b263b, #0d1b2a);
    color: white;
    text-align: center;
    padding: 100px 20px;
}

.hero h1 {
    font-size: 3rem;
    margin-bottom: 15px;
}

.hero p {
    font-size: 1.2rem;
    margin-bottom: 20px;
}

.btn {
    padding: 12px 25px;
    background: #4cc9f0;
    color: black;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

.btn:hover {
    background: #38bdf8;
}

/* SECTION */
.section {
    padding: 60px 40px;
    text-align: center;
}

.section h2 {
    margin-bottom: 30px;
}

/* SERVICES */
.services {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
}

.card {
    background: white;
    padding: 25px;
    border-radius: 10px;
    transition: 0.3s;
}

.card i {
    font-size: 30px;
    margin-bottom: 10px;
    color: #4cc9f0;
}

.card:hover {
    transform: translateY(-5px);
}

/* WHY */
.why {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

/* CONTACT */
.contact p {
    margin: 10px 0;
}

/* FOOTER */
footer {
    background: #0d1b2a;
    color: white;
    text-align: center;
    padding: 20px;
}

footer a {
    color: #4cc9f0;
    margin: 0 10px;
    text-decoration: none;
}

</style>
</head>

<body>

<nav>
    <h2>Adibas Host</h2>
    <div>
        <a href="#services">Services</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
    </div>
</nav>

<section class="hero">
    <h1>Reliable Hosting & IT Solutions</h1>
    <p>Fast, Secure, and Affordable Services for Your Business</p>
    <a href="#contact"><button class="btn">Contact Us</button></a>
</section>

<section class="section" id="services">
    <h2>Our Services</h2>
    <div class="services">
        <div class="card">
            <i class="fas fa-server"></i>
            <h3>Web Hosting</h3>
        </div>
        <div class="card">
            <i class="fas fa-globe"></i>
            <h3>Domain Registration</h3>
        </div>
        <div class="card">
            <i class="fas fa-envelope"></i>
            <h3>Business Email</h3>
        </div>
        <div class="card">
            <i class="fas fa-video"></i>
            <h3>CCTV Installation</h3>
        </div>
        <div class="card">
            <i class="fas fa-laptop-code"></i>
            <h3>IT Solutions</h3>
        </div>
    </div>
</section>

<section class="section" id="about">
    <h2>About Us</h2>
    <p>Since 2009, Adibas Host has been providing trusted hosting and IT solutions with strong customer support and reliable services across India.</p>
</section>

<section class="section">
    <h2>Why Choose Us</h2>
    <div class="why">
        <div class="card">⚡ Fast Servers</div>
        <div class="card">📞 24/7 Support</div>
        <div class="card">💰 Affordable Pricing</div>
        <div class="card">⭐ Trusted by Clients</div>
    </div>
</section>

<section class="section contact" id="contact">
    <h2>Contact Us</h2>
    <p><i class="fas fa-phone"></i> +91 XXXXXXXX</p>
    <p><i class="fas fa-envelope"></i> info@adibashost.com</p>
    <p><i class="fas fa-location-dot"></i> India</p>
    <br>
    <a href="https://wa.me/91XXXXXXXXXX" target="_blank">
        <button class="btn">Chat on WhatsApp</button>
    </a>
</section>

<footer>
    <p>© 2026 Adibas Host</p>
    <div>
        <a href="#"><i class="fab fa-facebook"></i></a>
        <a href="#"><i class="fab fa-instagram"></i></a>
        <a href="#"><i class="fab fa-linkedin"></i></a>
    </div>
</footer>

</body>
</html>
